# Copy this file to .env and adjust if needed.
# Default values are fine for local development.

POSTGRES_USER=crypto
POSTGRES_PASSWORD=cryptopass
POSTGRES_DB=crypto

GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Kafka bootstrap server as seen from the host machine.
# Inside the Docker network, services use kafka:9092 (not this).
KAFKA_BOOTSTRAP=localhost:29092
